# ─────────────────────────────────────────────────────────────────
#  FsocietyPK – Backend Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/fsocietypk
MONGODB_URI_PROD=mongodb+srv://<user>:<password>@cluster.mongodb.net/fsocietypk

# ── Authentication ────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Admin Seed ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@fsocietypk.com
ADMIN_PASSWORD=ChangeMe@123
ADMIN_USERNAME=fsociety_admin

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=debug
